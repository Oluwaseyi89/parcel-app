# Copy this file to `.env` and fill in real values.
DJANGO_SECRET_KEY=replace-with-your-secret-key
EMAIL_HOST=smtp.example.com
EMAIL_HOST_USER=you@example.com
EMAIL_HOST_PASSWORD=super-secret-password
RECIPIENT_ADDRESS=recipient@example.com
# Optional Redis/Celery URL
REDIS_URL=redis://localhost:6379/0
# PostgreSQL database settings (or use DATABASE_URL)
# Example DATABASE_URL: postgres://user:password@localhost:5432/parcel_db
# DATABASE_URL=postgres://postgres:password@127.0.0.1:5432/parcel_db
# Or set individual vars below:
# DATABASE_NAME=parcel_db
# DATABASE_USER=postgres
# DATABASE_PASSWORD=
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=5432

SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_PASSWORD=StrongPassword123

AWS_ACCESS_KEY_ID=xxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxx
AWS_STORAGE_BUCKET_NAME=xxxxxxxxxxxx
AWS_S3_REGION_NAME=xxxxxxxxxxxx
AWS_S3_SIGNATURE_VERSION=xxxxxxxxxxxx
AWS_S3_CUSTOM_DOMAIN=xxxxxxxxxxxx
AWS_S3_FILE_OVERWRITE=False
AWS_DEFAULT_ACL=None
USE_S3=True
