# Copy this file to `.env` and fill in real values.
DJANGO_SECRET_KEY=replace-with-your-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DJANGO_CORS_ALLOW_CREDENTIALS=True

# Cookie defaults for local dev:
# - Lax + insecure works across localhost ports because they are same-site.
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SAMESITE=Lax

# Optional auth-session cookie overrides. In production with frontend/backend on
# different sites, prefer Secure + SameSite=None and set cookie domains explicitly.
DJANGO_AUTH_SESSION_COOKIE_SECURE=False
DJANGO_AUTH_SESSION_COOKIE_SAMESITE=Lax
DJANGO_AUTH_SESSION_COOKIE_DOMAIN=
DJANGO_AUTH_MARKER_COOKIE_SECURE=False
DJANGO_AUTH_MARKER_COOKIE_SAMESITE=Lax
DJANGO_AUTH_MARKER_COOKIE_DOMAIN=

EMAIL_HOST=smtp.example.com
EMAIL_HOST_USER=you@example.com
EMAIL_HOST_PASSWORD=super-secret-password
RECIPIENT_ADDRESS=recipient@example.com
# Optional Redis/Celery URL
REDIS_URL=redis://localhost:6379/0
# PostgreSQL database settings (or use DATABASE_URL)
# Example DATABASE_URL: postgres://user:password@localhost:5432/parcel_db
# DATABASE_URL=postgres://postgres:password@127.0.0.1:5432/parcel_db
# Or set individual vars below:
# DATABASE_NAME=parcel_db
# DATABASE_USER=postgres
# DATABASE_PASSWORD=
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=5432

SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_PASSWORD=StrongPassword123

# AWS S3 media storage
USE_S3=True
AWS_ACCESS_KEY_ID=xxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxx
AWS_STORAGE_BUCKET_NAME=oluwaseyi89-bucket
AWS_S3_REGION_NAME=us-east-1
AWS_S3_SIGNATURE_VERSION=s3v4
AWS_S3_CUSTOM_DOMAIN=oluwaseyi89-bucket.s3.us-east-1.amazonaws.com
AWS_S3_ENDPOINT_URL=
AWS_LOCATION=media
S3_MEDIA_PUBLIC=False
AWS_S3_FILE_OVERWRITE=False
AWS_DEFAULT_ACL=None
AWS_QUERYSTRING_AUTH=True
AWS_S3_ENCRYPTION=AES256
AWS_S3_ADDRESSING_STYLE=virtual
AWS_S3_URL_PROTOCOL=https:
AWS_S3_VERIFY=True
AWS_S3_CACHE_CONTROL=max-age=86400
